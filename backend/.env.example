# Phonograph backend configuration

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://phonograph:phonograph@localhost:5432/phonograph

# JWT signing secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-please-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# First user created with this email is auto-promoted to admin + approved
INITIAL_ADMIN_EMAIL=admin@example.com

# CORS: comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Google OAuth2 (optional - leave blank to disable OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback
